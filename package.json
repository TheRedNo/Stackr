{
  "name": "Stackr",
  "version": "1.0.3",
  "description": "",
  "main": "electron/main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "vite",
    "electron": "electron .",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "publish": "npm run build && electron-builder --publish always"
  },
  "keywords": [],
  "author": "TheRedNo",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.16",
    "@vitejs/plugin-react": "^6.0.2",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.21.0",
    "png-to-ico": "^3.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "build": {
    "appId": "de.theredno.stackr",
    "productName": "Stackr",
    "publish": {
        "provider": "github",
        "owner": "TheRedNo",
        "repo": "Stackr",
        "releaseType": "draft"
      },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/assets/logo.png",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
